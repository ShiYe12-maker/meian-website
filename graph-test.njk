title: 图谱测试
permalink: /graph-test/
---

<div class="container">
  <div id="testChart" style="width:100%;height:500px;background:var(--color-card);border:1px solid var(--color-border);"></div>
</div>

<script src="/js/vendor/echarts.min.js"></script>
<script>
(function() {
  var c = document.getElementById('testChart');
  var chart = echarts.init(c);
  chart.setOption({
    series: [{
      type: 'graph',
      layout: 'force',
      roam: true,
      data: [
        { name: '毛泽东', symbolSize: 60, itemStyle: { color: '#527158' } },
        { name: '邓中夏', symbolSize: 50, itemStyle: { color: '#527158' } },
        { name: '瞿秋白', symbolSize: 50, itemStyle: { color: '#527158' } },
      ],
      links: [
        { source: '毛泽东', target: '邓中夏', label: { show: true, formatter: '同志' } },
        { source: '毛泽东', target: '瞿秋白', label: { show: true, formatter: '同志' } },
      ],
      label: { show: true, position: 'bottom', fontSize: 14, color: '#333' },
      force: { repulsion: 200, edgeLength: [100, 200] },
    }],
  });
})();
</script>
